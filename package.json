{
  "name": "james-and-sons",
  "private": true,
  "workspaces": [
    "admin",
    "storefront",
    "backend"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace=@james-andsons/admin",
    "dev:storefront": "npm run dev --workspace=@james-andsons/storefront",
    "dev:backend": "npm run start:dev --workspace=@james-andsons/backend",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "packageManager": "yarn@4.14.1"
}
